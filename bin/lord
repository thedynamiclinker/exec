#!/usr/bin/env bash

source ~/.bashrc

set -euo pipefail

exec_root="${EXEC:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)}"
verbose=0
echo_only=0
profile="${LORD_PROFILE:-}"
use_agents=1
created_agents=0
flags=()
prompt_args=()

usage() {
    cat <<'EOF'
usage: lord [options] [@options] [prompt ...]

Run codex exec with a temporary AGENTS.md profile unless ./AGENTS.md exists.

Options:
  -h, --help                  show this help
  -v, --verbose               show wrapper behavior and stream codex output
  -f, --force, --dont-panic   pass --dangerously-bypass-approvals-and-sandbox
      --fast, --quick         set reasoning effort to low
      --accurate, --careful   set reasoning effort to high
      --very-careful, --xhigh set reasoning effort to xhigh
      --effort LEVEL          set effort: low, medium, high, xhigh
      --thinking LEVEL        same as --effort
      --                      stop option parsing

@options:
  @echo                       print the codex exec command instead of running it
  @yhwh                       pass --skip-git-repo-check and do not use AGENTS.md
  @no-agents                  do not use AGENTS.md
  @profile=NAME              select a profile
  @agents=NAME               same as @profile
  @pray=NAME                 same as @profile
  @effort=LEVEL              set effort: low, medium, high, xhigh
  @thinking=LEVEL            same as @effort
  @fast, @quick              set reasoning effort to low
  @accurate, @careful        set reasoning effort to high
  @very-careful, @xhigh      set reasoning effort to xhigh
  @FLAG                      pass --FLAG to codex exec

Default profile:
  ./AGENTS.md if it exists; otherwise repo inside a Git worktree; otherwise unix-command.
EOF
}

in_git_repo() {
    git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

profile_pattern() {
    case "$1" in
        repo|git|code) printf '%s\n' 'code' ;;
        unix|command|unix-command) printf '%s\n' 'unix-command' ;;
        bible|nameless|we-the-nameless) printf '%s\n' 'bible' ;;
        *) printf '%s\n' "$1" ;;
    esac
}

set_effort() {
    local effort="$1"

    case "$effort" in
        low|medium|high|xhigh) ;;
        *)
            printf 'lord: unknown effort: %s\n' "$effort" >&2
            printf 'lord: expected one of: low medium high xhigh\n' >&2
            exit 2
            ;;
    esac

    flags+=( -c "model_reasoning_effort=\"$effort\"" )
}

log() {
    if ((verbose)); then
        printf 'lord: %s\n' "$*" >&2
    fi
}

cleanup() {
    if ((created_agents)); then
        rm -f AGENTS.md
    fi
}

while (($#)); do
    case "$1" in
        -h|--help)
            usage
            exit
            ;;
        -v|--verbose)
            verbose=1
            shift
            ;;
        -f|--force|--dont-panic)
            flags+=( --dangerously-bypass-approvals-and-sandbox )
            shift
            ;;
        --fast|--quick)
            set_effort low
            shift
            ;;
        --accurate|--careful)
            set_effort high
            shift
            ;;
        --very-careful|--xhigh)
            set_effort xhigh
            shift
            ;;
        --effort|--thinking)
            if (($# < 2)); then
                printf 'lord: %s needs an argument\n' "$1" >&2
                exit 2
            fi
            set_effort "$2"
            shift 2
            ;;
        --effort=*|--thinking=*)
            set_effort "${1#*=}"
            shift
            ;;
        --)
            shift
            prompt_args+=( "$@" )
            break
            ;;
        -*)
            prompt_args+=( "$1" )
            shift
            ;;
        *)
            break
            ;;
    esac
done

while (($#)); do
    case "$1" in
        -h|--help)
            usage
            exit
            ;;
        @echo)
            echo_only=1
            shift
            ;;
        @yhwh)
            flags+=( --skip-git-repo-check )
            use_agents=0
            shift
            ;;
        @pray=*)
            profile="${1#@pray=}"
            shift
            ;;
        @profile=*|@agents=*)
            profile="${1#*=}"
            shift
            ;;
        @effort=*|@thinking=*)
            set_effort "${1#*=}"
            shift
            ;;
        @fast|@quick)
            set_effort low
            shift
            ;;
        @accurate|@careful)
            set_effort high
            shift
            ;;
        @very-careful|@xhigh)
            set_effort xhigh
            shift
            ;;
        --fast|--quick)
            set_effort low
            shift
            ;;
        --accurate|--careful)
            set_effort high
            shift
            ;;
        --very-careful|--xhigh)
            set_effort xhigh
            shift
            ;;
        --effort|--thinking)
            if (($# < 2)); then
                printf 'lord: %s needs an argument\n' "$1" >&2
                exit 2
            fi
            set_effort "$2"
            shift 2
            ;;
        --effort=*|--thinking=*)
            set_effort "${1#*=}"
            shift
            ;;
        @no-agents)
            use_agents=0
            shift
            ;;
        --)
            shift
            prompt_args+=( "$@" )
            break
            ;;
        @*)
            flags+=( "--${1#@}" )
            shift
            ;;
        *)
            prompt_args+=( "$1" )
            shift
            ;;
    esac
done

if [[ -z "$profile" ]]; then
    if [[ -e AGENTS.md ]]; then
        profile=
    elif in_git_repo; then
        profile=repo
    else
        profile=unix-command
    fi
fi

if ! in_git_repo; then
    flags+=( --skip-git-repo-check -s workspace-write )
fi

prompt="${prompt_args[*]}"

install_agents() {
    local file name target pattern
    local matches=()

    if ! ((use_agents)); then
        return 0
    fi

    if [[ -e AGENTS.md ]]; then
        log "using existing AGENTS.md"
        return
    fi

    pattern="$(profile_pattern "$profile")"

    shopt -s nullglob
    for file in "$exec_root"/etc/lord/*.md; do
        name="$(basename -- "$file")"
        if [[ "$name" =~ $pattern || "$file" =~ $pattern ]]; then
            matches+=( "$file" )
        fi
    done

    if ((${#matches[@]} != 1)); then
        {
            echo "The lord cannot hear your prayer:"
            printf '%s\n' "${matches[@]}"
        } >&2
        exit 1
    fi

    target="${matches[0]}"
    ln -s -- "$target" AGENTS.md
    created_agents=1
    trap cleanup EXIT INT TERM HUP
    log "linked AGENTS.md -> $target"
}

run() {
    local err output status latest
    local cmd=( codex exec "${flags[@]}" -- "$prompt" )

    if ((echo_only)); then
        printf '%q' "${cmd[0]}"
        printf ' %q' "${cmd[@]:1}"
        printf '\n'
        return
    fi

    log "running: ${cmd[*]}"

    if ((verbose)); then
        "${cmd[@]}"
        return
    fi

    err="$(mktemp)"
    set +e
    output="$("${cmd[@]}" 2>"$err")"
    status=$?
    set -e

    if ((status != 0)); then
        cat "$err" >&2
        rm -f "$err"
        return "$status"
    fi

    rm -f "$err"

    latest="$(date +%Y%m%d-%H%M%S.%3N)"
    mkdir -p "$HOME/.cache/lord"
    printf '%s\n' "$output" | tee "$HOME/.cache/lord/$latest"
}

install_agents
run
