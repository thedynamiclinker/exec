#!/usr/bin/env bash

source ~/.bashrc

set -euo pipefail

exec_root="${EXEC:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)}"
verbose=0
echo_only=0
profile="${LORD_PROFILE:-unix-command}"
use_agents=1
created_agents=0
flags=()
prompt_args=()

log() {
    if ((verbose)); then
        printf 'lord: %s\n' "$*" >&2
    fi
}

cleanup() {
    if ((created_agents)); then
        rm -f AGENTS.md
    fi
}

while (($#)); do
    case "$1" in
        -v|--verbose)
            verbose=1
            shift
            ;;
        -f|--force|--dont-panic)
            flags+=( --dangerously-bypass-approvals-and-sandbox )
            shift
            ;;
        --)
            shift
            prompt_args+=( "$@" )
            break
            ;;
        -*)
            prompt_args+=( "$1" )
            shift
            ;;
        *)
            break
            ;;
    esac
done

for x; do
    case "$x" in
        @echo)
            echo_only=1
            ;;
        @yhwh)
            flags+=( --skip-git-repo-check )
            use_agents=0
            ;;
        @pray=*)
            profile="${x#@pray=}"
            ;;
        @profile=*)
            profile="${x#@profile=}"
            ;;
        @no-agents)
            use_agents=0
            ;;
        @*)
            flags+=( "--${x#@}" )
            ;;
        *)
            prompt_args+=( "$x" )
            ;;
    esac
done

if [[ ! -d .git ]]; then
    flags+=( --skip-git-repo-check -s workspace-write )
fi

prompt="${prompt_args[*]}"

install_agents() {
    local file name target
    local matches=()

    if ! ((use_agents)); then
        return 0
    fi

    if [[ -e AGENTS.md ]]; then
        log "using existing AGENTS.md"
        return
    fi

    shopt -s nullglob
    for file in "$exec_root"/etc/lord/*.md; do
        name="$(basename -- "$file")"
        if [[ "$name" =~ $profile || "$file" =~ $profile ]]; then
            matches+=( "$file" )
        fi
    done

    if ((${#matches[@]} != 1)); then
        {
            echo "The lord cannot hear your prayer:"
            printf '%s\n' "${matches[@]}"
        } >&2
        exit 1
    fi

    target="${matches[0]}"
    ln -s -- "$target" AGENTS.md
    created_agents=1
    trap cleanup EXIT INT TERM HUP
    log "linked AGENTS.md -> $target"
}

run() {
    local err output status latest
    local cmd=( codex exec "${flags[@]}" -- "$prompt" )

    if ((echo_only)); then
        printf '%q ' "${cmd[@]}"
        printf '\n'
        return
    fi

    log "running: ${cmd[*]}"

    if ((verbose)); then
        "${cmd[@]}"
        return
    fi

    err="$(mktemp)"
    set +e
    output="$("${cmd[@]}" 2>"$err")"
    status=$?
    set -e

    if ((status != 0)); then
        cat "$err" >&2
        rm -f "$err"
        return "$status"
    fi

    rm -f "$err"

    latest="$(date +%Y%m%d-%H%M%S.%3N)"
    mkdir -p "$HOME/.cache/lord"
    printf '%s\n' "$output" | tee "$HOME/.cache/lord/$latest"
}

install_agents
run
