#!/usr/bin/env bash

source ~/.bashrc

verbose=0
echo_only=0
use_tempdir=1
flags=()

while (($#)); do
    case "$1" in
        -v|--verbose)
            verbose=1
            shift
            ;;
        @echo)
            echo_only=1
            shift
            ;;
        @yhwh)
            flags+=( --skip-git-repo-check )
            use_tempdir=0
            shift
            ;;
        *)
            break
            ;;
    esac
done

prompt="$*"

cleanup() {
    rm -f AGENTS.md
}

run_codex() {
    local err output status
    local cmd=( codex exec "${flags[@]}" -- "$prompt" )

    if (( echo_only )); then
        echo "${cmd[@]}"
        return
    fi

    if (( verbose )); then
        "${cmd[@]}"
        return
    fi

    err="$(mktemp)"
    output="$("${cmd[@]}" 2>"$err")"
    status=$?

    if (( status != 0 )); then
        cat "$err" >&2
        rm -f "$err"
        return "$status"
    fi

    rm -f "$err"

    latest="$(date +%Y%m%d-%H%M%S.%3N)"
    mkdir -p "$HOME/.cache/lord"
    echo "$output" | tee "$HOME/.cache/lord/$latest"
}

main() {
    if [[ -d .git ]]; then
        use_tempdir=0
    fi

    if (( use_tempdir )); then
        cd "$(mktemp -d)" || exit
    fi

    if [[ -e AGENTS.md ]]; then
        echo "AGENTS.md already exists, but we need to overwrite it before the lord can work."
        exit 1
    fi

    pray > AGENTS.md
    trap cleanup EXIT INT TERM HUP

    run_codex
}

main "$@"
