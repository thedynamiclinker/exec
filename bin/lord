#!/usr/bin/env bash

source ~/.bashrc

verbose=0

case "${1-}" in
    -v|--verbose)
        verbose=1
        shift
        ;;
esac

prompt="$*"

pushd "$EXEC/etc/lord" >/dev/null

if (( verbose )); then
    output="$(codex exec "$prompt")"
else
    err="$(mktemp)"
    output="$(codex exec "$prompt" 2>"$err")"
    status=$?

    if (( status != 0 )); then
        cat "$err" >&2
        rm -f "$err"
        exit "$status"
    fi

    rm -f "$err"
fi

echo "$output" | tee ~/.cache/lord/$PPID

popd >/dev/null

exit 0

#################################
### EXAMPLE USAGE OF THE LORD ###
#################################

# printf 'explain why chicken is religious\nhow do i save 15% on car insurance\nwho wrote caravan of dreams\nwho wrote the tale of melon city\n' | xargs -I{} echo {} --json-list key-for-question-key-for-answer --sed 's/150n/15%/' | lord | jq

# lord set theoretic intersection of head of porn magazine company initials and neonazi slogans
HH

# lord snake in hebrew but write it in latin alphabet only conson --upper --heth-is-H --ipa-for-digraphs
NHʃ


