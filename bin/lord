#!/usr/bin/env bash

source ~/.bashrc

set -euo pipefail

exec_root="${EXEC:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)}"

verbose=0
quiet=0
echo_only=0
use_agents=1
created_agents=0
profile="${LORD_PROFILE:-}"
flags=()
prompt_args=()
lock_dir=
chat_dir=

usage() {
    cat <<'EOF'
usage: lord [options] [@mode] [prompt ...]

Run codex exec with one of four profiles:

  @repo    code/repository work. Default inside a Git worktree.
  @unix    Unix-filter work. Default outside a Git worktree.
  @book    long-form explanation, exegesis, and careful reading.
  @chat    answer a question without touching the current worktree.

If ./AGENTS.md is a real local file, lord leaves it alone and Codex reads it.
If ./AGENTS.md is one of lord's own profile links, lord may replace it.

Options:
  -h, --help            show this help
  -v, --verbose         show wrapper behavior and stream codex output
  -q, --quiet           capture codex output, even in verbose-by-default modes
  -f, --force           pass --dangerously-bypass-approvals-and-sandbox
      --effort LEVEL    set reasoning effort: low, medium, high, xhigh
      --fast            same as --effort low
      --careful         same as --effort high
      --xhigh           same as --effort xhigh
      --no-agents       do not install an AGENTS.md profile
      --profile NAME    select profile by name: repo, unix, book, chat
      --                stop option parsing

@options:
  @repo, @unix, @book,
  @chat                select mode
  @profile=NAME        select profile by name
  @no-agents           do not install an AGENTS.md profile
  @echo                print the codex exec command instead of running it
  @effort=LEVEL        set reasoning effort
  @fast, @careful,
  @xhigh               effort shorthands
  @FLAG                pass --FLAG to codex exec

Sandbox:
  In a Git worktree, lord adds -s workspace-write, except for @chat.
  Unix mode also gets workspace-write, even outside Git.
  Chat mode uses read-only, ephemeral Codex execution in a temporary directory.
EOF
}

in_git_repo() {
    git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

log() {
    if ((verbose)); then
        printf 'lord: %s\n' "$*" >&2
    fi
}

cleanup() {
    if ((created_agents)); then
        rm -f AGENTS.md
    fi
    if [[ -n "$lock_dir" ]]; then
        rmdir -- "$lock_dir" 2>/dev/null || true
    fi
    if [[ -n "$chat_dir" ]]; then
        rm -rf -- "$chat_dir"
    fi
}

set_effort() {
    local effort="$1"

    case "$effort" in
        low|medium|high|xhigh) ;;
        *)
            printf 'lord: unknown effort: %s\n' "$effort" >&2
            printf 'lord: expected one of: low medium high xhigh\n' >&2
            exit 2
            ;;
    esac

    flags+=( -c "model_reasoning_effort=\"$effort\"" )
}

canonical_profile() {
    case "$1" in
        repo|git|code) printf '%s\n' repo ;;
        unix|command|unix-command|filter) printf '%s\n' unix ;;
        book|bible|nameless|we-the-nameless) printf '%s\n' book ;;
        chat|ask|question|qa) printf '%s\n' chat ;;
        "")
            printf 'lord: empty profile name\n' >&2
            exit 2
            ;;
        *)
            printf 'lord: unknown profile: %s\n' "$1" >&2
            printf 'lord: expected one of: repo unix book chat\n' >&2
            exit 2
            ;;
    esac
}

select_profile() {
    profile="$(canonical_profile "$1")"
}

profile_file() {
    printf '%s/etc/lord/AGENTS-%s.md\n' "$exec_root" "$profile"
}

profile_uses_agents() {
    [[ "$profile" != chat ]]
}

agents_link_is_ours() {
    local link target abs_target

    [[ -L AGENTS.md ]] || return 1

    link="$(readlink -- AGENTS.md)" || return 1
    case "$link" in
        /*) target="$link" ;;
        *) target="$PWD/$link" ;;
    esac

    abs_target="$(realpath -m -- "$target")"
    [[ "$abs_target" == "$exec_root"/etc/lord/AGENTS-*.md ]]
}

real_local_agents_exists() {
    [[ -e AGENTS.md || -L AGENTS.md ]] && ! agents_link_is_ours
}

parse_option() {
    case "$1" in
        -h|--help)
            usage
            exit
            ;;
        -v|--verbose)
            verbose=1
            ;;
        -q|--quiet)
            quiet=1
            ;;
        -f|--force|--dont-panic)
            flags+=( --dangerously-bypass-approvals-and-sandbox )
            ;;
        --no-agents|@no-agents)
            use_agents=0
            ;;
        @echo)
            echo_only=1
            ;;
        @yhwh)
            use_agents=0
            flags+=( --skip-git-repo-check )
            ;;
        --fast|@fast|--quick|@quick)
            set_effort low
            ;;
        --careful|@careful|--accurate|@accurate)
            set_effort high
            ;;
        --xhigh|@xhigh|--very-careful|@very-careful)
            set_effort xhigh
            ;;
        @repo|@unix|@book|@chat)
            select_profile "${1#@}"
            ;;
        @profile=*|@agents=*|@pray=*)
            select_profile "${1#*=}"
            ;;
        @effort=*|@thinking=*)
            set_effort "${1#*=}"
            ;;
        @*)
            flags+=( "--${1#@}" )
            ;;
        *)
            return 1
            ;;
    esac
}

while (($#)); do
    case "$1" in
        --)
            shift
            prompt_args+=( "$@" )
            break
            ;;
        --effort|--thinking)
            if (($# < 2)); then
                printf 'lord: %s needs an argument\n' "$1" >&2
                exit 2
            fi
            set_effort "$2"
            shift 2
            continue
            ;;
        --effort=*|--thinking=*)
            set_effort "${1#*=}"
            shift
            continue
            ;;
        --profile|--agents)
            if (($# < 2)); then
                printf 'lord: %s needs an argument\n' "$1" >&2
                exit 2
            fi
            select_profile "$2"
            shift 2
            continue
            ;;
        --profile=*|--agents=*)
            select_profile "${1#*=}"
            shift
            continue
            ;;
    esac

    if parse_option "$1"; then
        shift
    else
        prompt_args+=( "$1" )
        shift
    fi
done

git_repo=0
if in_git_repo; then
    git_repo=1
fi

if [[ -n "$profile" ]]; then
    profile="$(canonical_profile "$profile")"
elif real_local_agents_exists; then
    profile=
elif ((git_repo)); then
    profile=repo
else
    profile=unix
fi

if ((quiet)); then
    verbose=0
elif [[ "$profile" != unix ]]; then
    verbose=1
fi

if [[ "$profile" == chat ]]; then
    flags+=( --skip-git-repo-check --ephemeral -s read-only )
elif ((git_repo)); then
    flags+=( --skip-git-repo-check -s workspace-write )
elif [[ "$profile" == unix ]]; then
    flags+=( --skip-git-repo-check -s workspace-write )
else
    flags+=( --skip-git-repo-check )
fi

install_agents() {
    local target

    if ! profile_uses_agents; then
        return 0
    fi

    if ! ((use_agents)); then
        if agents_link_is_ours; then
            rm -f AGENTS.md
        fi
        return 0
    fi

    [[ -n "$profile" ]] || return 0

    if real_local_agents_exists; then
        log "using real local AGENTS.md"
        return 0
    fi

    target="$(profile_file)"
    if [[ ! -f "$target" ]]; then
        printf 'lord: missing profile file: %s\n' "$target" >&2
        exit 1
    fi

    if agents_link_is_ours; then
        rm -f AGENTS.md
    fi

    ln -s -- "$target" AGENTS.md
    created_agents=1
    trap cleanup EXIT INT TERM HUP
    log "linked AGENTS.md -> $target"
}

lock_worktree_agents() {
    local i
    if [[ -z "$profile" ]] || ! profile_uses_agents; then
        return 0
    fi

    lock_dir=".lord-agents.lock"

    for i in {1..100}; do
        if mkdir -- "$lock_dir" 2>/dev/null; then
            trap cleanup EXIT INT TERM HUP
            return 0
        fi
        sleep 0.1
    done

    printf 'lord: timed out waiting for %s\n' "$lock_dir" >&2
    exit 1
}

run() {
    local err output status latest prompt
    prompt="${prompt_args[*]}"

    if [[ "$profile" == chat ]]; then
        chat_dir="$(mktemp -d "${TMPDIR:-/tmp}/lord-chat.XXXXXX")"
        flags+=( -C "$chat_dir" )
        prompt="$(cat -- "$(profile_file)")"$'\n\n'"$prompt"
        trap cleanup EXIT INT TERM HUP
    fi

    local cmd=( codex exec "${flags[@]}" -- "$prompt" )

    if ((echo_only)); then
        printf '%q' "${cmd[0]}"
        printf ' %q' "${cmd[@]:1}"
        printf '\n'
        return
    fi

    log "running: ${cmd[*]}"

    if ((verbose)); then
        "${cmd[@]}"
        return
    fi

    err="$(mktemp)"
    set +e
    output="$("${cmd[@]}" 2>"$err")"
    status=$?
    set -e

    if ((status != 0)); then
        cat "$err" >&2
        rm -f "$err"
        return "$status"
    fi

    rm -f "$err"

    latest="$(date +%Y%m%d-%H%M%S.%3N)"
    mkdir -p "$HOME/.cache/lord"
    printf '%s\n' "$output" | tee "$HOME/.cache/lord/$latest"
}

lock_worktree_agents
install_agents
run
