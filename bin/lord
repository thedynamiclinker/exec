#!/usr/bin/env bash

source ~/.bashrc

verbose=0
dammit=0

case "${1-}" in
    -v|--verbose)
        verbose=1
        shift
        ;;
    -d|--dammit)
        dammit=1
        shift
        ;;
esac

prompt="$*"

cleanup() {
    local rc=$?
    rm -f AGENTS.md
    exit "$rc"
}
trap cleanup EXIT INT TERM HUP

if [[ -z "$dammit" ]]; then
    if [[ -e AGENTS.md ]]; then
        echo "AGENTS.md already exists, but we need to overwrite it before the lord can work."
        exit 1
    else
        pray > AGENTS.md
    fi
fi

if (( verbose )); then
    output="$(codex exec -- "$prompt")"
else
    err="$(mktemp)"
    output="$(codex exec -- "$prompt" 2>"$err")"
    status=$?

    if (( status != 0 )); then
        cat "$err" >&2
        rm -f "$err"
        exit "$status"
    fi

    rm -f "$err"
fi

rm -f AGENTS.md

latest="$(date +%Y%m%d-%H%M%S.%3N)"
echo "$output" | tee "$HOME/.cache/lord/$latest"

exit 0
