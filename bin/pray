#!/usr/bin/env bash

set -euo pipefail

exec_root="${EXEC:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}"
pattern="${*:-unix}"

mapfile -t matches < <(
    find "$exec_root/etc/lord" -maxdepth 1 -type f -name '*.md' -printf '%p\n' |
        sort |
        grep -E -- "$pattern" || true
)

if ((${#matches[@]} == 1)); then
    cat "${matches[0]}"
    exit
fi

echo "The lord cannot hear your prayer:" >&2
printf '%s\n' "${matches[@]}" >&2
exit 1
