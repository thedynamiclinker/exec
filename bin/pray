#!/usr/bin/env bash

set -euo pipefail

exec_root="${EXEC:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)}"
pattern="${*:-}"

matches=()
shopt -s nullglob
for file in "$exec_root"/etc/lord/*.md; do
    name="$(basename -- "$file")"
    if [[ "$name" =~ $pattern || "$file" =~ $pattern ]]; then
        matches+=( "$file" )
    fi
done

if ((${#matches[@]} == 1)); then
    cat -- "${matches[0]}"
    exit
fi

{
    echo "The lord cannot hear your prayer:"
    printf '%s\n' "${matches[@]}"
} >&2
exit 1
