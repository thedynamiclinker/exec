#!/usr/bin/env python3

import os
import subprocess
import sys
import tempfile
from pathlib import Path


def cleanup(rc):
    try:
        Path("AGENTS.md").unlink()
    except FileNotFoundError:
        pass
    raise SystemExit(rc)


def main():
    argv = sys.argv[1:]
    verbose = 0
    dammit = 0

    if argv:
        if argv[0] in ("-v", "--verbose"):
            verbose = 1
            argv = argv[1:]
        elif argv[0] in ("-d", "--dammit"):
            dammit = 1
            argv = argv[1:]

    prompt = " ".join(argv)
    agents = Path("AGENTS.md")

    if agents.exists() and not dammit:
        print("AGENTS.md already exists, but we need to overwrite it before the lord can work.")
        return 1

    try:
        with agents.open("w") as f:
            subprocess.run(["pray"], stdout=f, check=True)

        if verbose:
            p = subprocess.run(
                ["codex", "exec", "--", prompt],
                text=True,
                stdout=subprocess.PIPE,
            )
            output = p.stdout
            if p.returncode:
                return p.returncode
        else:
            with tempfile.NamedTemporaryFile(delete=False) as err:
                err_path = err.name

            try:
                with open(err_path, "w") as err:
                    p = subprocess.run(
                        ["codex", "exec", "--", prompt],
                        text=True,
                        stdout=subprocess.PIPE,
                        stderr=err,
                    )

                output = p.stdout

                if p.returncode:
                    with open(err_path) as err:
                        sys.stderr.write(err.read())
                    return p.returncode
            finally:
                try:
                    os.unlink(err_path)
                except FileNotFoundError:
                    pass

        agents.unlink(missing_ok=True)

        latest = subprocess.check_output(
            ["date", "+%Y%m%d-%H%M%S.%3N"],
            text=True,
        ).strip()

        cache = Path.home() / ".cache" / "lord" / latest
        cache.parent.mkdir(parents=True, exist_ok=True)

        sys.stdout.write(output)
        with cache.open("w") as f:
            f.write(output)

        return 0
    finally:
        agents.unlink(missing_ok=True)


if __name__ == "__main__":
    raise SystemExit(main())
