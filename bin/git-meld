#!/usr/bin/env bash
set -euo pipefail

die() {
    echo "git-meld: $*" >&2
    exit 1
}

command -v git >/dev/null || die "git not found"
command -v meld >/dev/null || die "meld not found"

git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
    || die "not inside a git repo"

# Set only if unset.
if ! git config --global --get diff.tool >/dev/null; then
    git config --global diff.tool meld
fi

if ! git config --global --get difftool.prompt >/dev/null; then
    git config --global difftool.prompt false
fi

if ! git config --global --get difftool.meld.cmd >/dev/null; then
    git config --global difftool.meld.cmd 'meld "$LOCAL" "$REMOTE"'
fi

git difftool "$@"
