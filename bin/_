#!/usr/bin/env bash

[ ! -t 0 ] && {
    now="$(date +%Y%m%d-%H%M%S.%3N)"
    cache="$HOME/.cache/lord/$now"
    cat > "$cache"
    exit 0
}

n=1
if [[ -n "$1" ]]; then
    n="$1"
fi
n=${n/-/}

cache="$(find $HOME/.cache/lord/ -type f | sort | tail -$n | head -1)"

if [[ ! -e "$cache" ]]; then
    echo "The lord has not yet known this shell."
    exit 1
fi

content="$(cat "$cache")"
echo "$content"
echo "$content" | xc
